<settings>    <mirrors>        <mirror>            <id>dg</id>            <mirrorOf>*,!Product-singletool-release,!cmc_central</mirrorOf>            <url>https://maven.cloudartifact.dgg-y.dragon.tools.huawei.com/artifactory/sz-maven-public/</url>        </mirror>    </mirrors>    <profiles>        <profile>            <id>corealm</id>            <repositories>                <repository>                    <id>Product-singletool-release</id>                    <url>                        https://maven.cloudartifact.dgg-y.dragon.tools.huawei.com/artifactory/Product-singletool-release                    </url>                    <releases>                        <enabled>true</enabled>                    </releases>                    <snapshots>                        <enabled>true</enabled>                    </snapshots>                </repository>            </repositories>        </profile>        <profile>            <id>cmc</id>            <repositories>                <repository>                    <id>cmc_central</id>                    <url>https://cmc.centralrepo.rnd.huawei.com/maven/</url>                    <releases>                        <enabled>true</enabled>                        <updatePolicy>always</updatePolicy>                    </releases>                    <snapshots>                        <enabled>false</enabled>                    </snapshots>                </repository>            </repositories>            <pluginRepositories>                <pluginRepository>                    <id>huawei-central-plugin</id>                    <name>huawei central plugin</name>                    <url>https://cmc.centralrepo.rnd.huawei.com/maven/</url>                </pluginRepository>            </pluginRepositories>        </profile>    </profiles>    <activeProfiles>        <activeProfile>corealm</activeProfile>        <activeProfile>cmc</activeProfile>    </activeProfiles></settings>