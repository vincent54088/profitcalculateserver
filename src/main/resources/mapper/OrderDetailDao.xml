    <insert id="batchInsert">
        INSERT INTO t_order_product_detail_data (
            id, task_id, order_id, device_type, device_id, description, category_type, hardware_type, scene, device_count, income_month, currency,
            list_price, before_tier, before_price, discount_desc_before, after_tier, after_price, discount_desc_after,
            tier_increase, price_increase, after_tier_discount_rate, after_price_discount_rate, before_total_price, after_total_price,
            total_price_increase, total_increase_rate, gross_profit, addition_info
        ) VALUES
        <foreach collection="rows" item="r" separator=",">
            (
            #{r.id}, #{r.taskId}, #{r.orderId}, #{r.deviceType}, #{r.deviceId}, #{r.description}, #{r.categoryType}, #{r.hardwareType}, #{r.scene},
            #{r.deviceCount}, #{r.incomeMonth}, #{r.currency}, #{r.listPrice}, #{r.beforeTier}, #{r.beforePrice}, #{r.discountDescBefore},
            #{r.afterTier}, #{r.afterPrice}, #{r.discountDescAfter}, #{r.tierIncrease}, #{r.priceIncrease}, #{r.afterTierDiscountRate},
            #{r.afterPriceDiscountRate}, #{r.beforeTotalPrice}, #{r.afterTotalPrice}, #{r.totalPriceIncrease}, #{r.totalIncreaseRate}, #{r.grossProfit}, #{r.additionInfo}
            )
        </foreach>
    </insert>

    <sql id="detailKeywordFilter">
        <if test="keyword != null and keyword != ''">
            AND (
            d.order_id LIKE CONCAT('%', #{keyword}, '%')
            OR IFNULL(d.device_id, '') LIKE CONCAT('%', #{keyword}, '%')
            OR IFNULL(d.device_type, '') LIKE CONCAT('%', #{keyword}, '%')
            OR IFNULL(d.description, '') LIKE CONCAT('%', #{keyword}, '%')
            OR IFNULL(d.category_type, '') LIKE CONCAT('%', #{keyword}, '%')
            OR IFNULL(d.hardware_type, '') LIKE CONCAT('%', #{keyword}, '%')
            OR IFNULL(d.scene, '') LIKE CONCAT('%', #{keyword}, '%')
            OR IFNULL(d.income_month, '') LIKE CONCAT('%', #{keyword}, '%')
            OR IFNULL(d.currency, '') LIKE CONCAT('%', #{keyword}, '%')
            OR IFNULL(d.discount_desc_before, '') LIKE CONCAT('%', #{keyword}, '%')
            OR IFNULL(d.discount_desc_after, '') LIKE CONCAT('%', #{keyword}, '%')
            OR IFNULL(d.addition_info, '') LIKE CONCAT('%', #{keyword}, '%')
            OR IFNULL(o.area, '') LIKE CONCAT('%', #{keyword}, '%')
            OR IFNULL(o.representative_office, '') LIKE CONCAT('%', #{keyword}, '%')
            OR IFNULL(o.country, '') LIKE CONCAT('%', #{keyword}, '%')
            OR IFNULL(o.accounts, '') LIKE CONCAT('%', #{keyword}, '%')
            OR IFNULL(o.project, '') LIKE CONCAT('%', #{keyword}, '%')
            OR IFNULL(o.po_id, '') LIKE CONCAT('%', #{keyword}, '%')
            OR IFNULL(o.product_domain, '') LIKE CONCAT('%', #{keyword}, '%')
            OR CAST(IFNULL(d.device_count, 0) AS CHAR) LIKE CONCAT('%', #{keyword}, '%')
            OR CAST(IFNULL(d.list_price, 0) AS CHAR) LIKE CONCAT('%', #{keyword}, '%')
            OR CAST(IFNULL(d.before_price, 0) AS CHAR) LIKE CONCAT('%', #{keyword}, '%')
            OR CAST(IFNULL(d.after_price, 0) AS CHAR) LIKE CONCAT('%', #{keyword}, '%')
            OR CAST(IFNULL(d.gross_profit, 0) AS CHAR) LIKE CONCAT('%', #{keyword}, '%')
            )
        </if>
    </sql>

