    <sql id="detailWhereFilters">
        <choose>
            <when test="columnFilters != null and columnFilters.size() &gt; 0">
                <include refid="detailColumnFiltersIn"/>
            </when>
            <otherwise>
                <include refid="detailKeywordFilter"/>
            </otherwise>
        </choose>
    </sql>

    <!-- 列去重可选值：只应用列筛选（与 column-options 接口一致，不引用 keyword） -->
    <sql id="detailWhereFiltersFacet">
        <if test="columnFilters != null and columnFilters.size() &gt; 0">
            <include refid="detailColumnFiltersIn"/>
        </if>
    </sql>

    <select id="listDistinctColumnValues" resultType="java.lang.String">
        SELECT DISTINCT
        <choose>
            <when test="field == 'orderId'">d.order_id</when>
            <when test="field == 'area'">IFNULL(o.area, '')</when>
            <when test="field == 'representativeOffice'">IFNULL(o.representative_office, '')</when>
            <when test="field == 'country'">IFNULL(o.country, '')</when>
            <when test="field == 'accounts'">IFNULL(o.accounts, '')</when>
            <when test="field == 'project'">IFNULL(o.project, '')</when>
            <when test="field == 'poId'">IFNULL(o.po_id, '')</when>
            <when test="field == 'productDomain'">IFNULL(o.product_domain, '')</when>
            <when test="field == 'grossProfit'">CAST(IFNULL(d.gross_profit, 0) AS CHAR)</when>
            <when test="field == 'deviceType'">IFNULL(d.device_type, '')</when>
            <when test="field == 'deviceId'">IFNULL(d.device_id, '')</when>
            <when test="field == 'description'">IFNULL(d.description, '')</when>
            <when test="field == 'categoryType'">IFNULL(d.category_type, '')</when>
            <when test="field == 'hardwareType'">IFNULL(d.hardware_type, '')</when>
            <when test="field == 'scene'">IFNULL(d.scene, '')</when>
            <when test="field == 'deviceCount'">CAST(IFNULL(d.device_count, 0) AS CHAR)</when>
            <when test="field == 'incomeMonth'">IFNULL(d.income_month, '')</when>
            <when test="field == 'currency'">IFNULL(d.currency, '')</when>
            <when test="field == 'listPrice'">CAST(IFNULL(d.list_price, 0) AS CHAR)</when>
            <when test="field == 'beforeTier'">CAST(IFNULL(d.before_tier, 0) AS CHAR)</when>
            <when test="field == 'beforePrice'">CAST(IFNULL(d.before_price, 0) AS CHAR)</when>
            <when test="field == 'discountDescBefore'">IFNULL(d.discount_desc_before, '')</when>
            <when test="field == 'afterTier'">CAST(IFNULL(d.after_tier, 0) AS CHAR)</when>
            <when test="field == 'afterPrice'">CAST(IFNULL(d.after_price, 0) AS CHAR)</when>
            <when test="field == 'discountDescAfter'">IFNULL(d.discount_desc_after, '')</when>
            <when test="field == 'tierIncrease'">CAST(IFNULL(d.tier_increase, 0) AS CHAR)</when>
            <when test="field == 'priceIncrease'">CAST(IFNULL(d.price_increase, 0) AS CHAR)</when>
            <when test="field == 'afterTierDiscountRate'">CAST(IFNULL(d.after_tier_discount_rate, 0) AS CHAR)</when>
            <when test="field == 'afterPriceDiscountRate'">CAST(IFNULL(d.after_price_discount_rate, 0) AS CHAR)</when>
            <when test="field == 'beforeTotalPrice'">CAST(IFNULL(d.before_total_price, 0) AS CHAR)</when>
            <when test="field == 'afterTotalPrice'">CAST(IFNULL(d.after_total_price, 0) AS CHAR)</when>
            <when test="field == 'totalPriceIncrease'">CAST(IFNULL(d.total_price_increase, 0) AS CHAR)</when>
            <when test="field == 'totalIncreaseRate'">CAST(IFNULL(d.total_increase_rate, 0) AS CHAR)</when>
            <when test="field == 'additionInfo'">IFNULL(d.addition_info, '')</when>
            <otherwise>d.order_id</otherwise>
        </choose>
        AS v
        FROM t_order_product_detail_data d
        LEFT JOIN t_order_info o ON d.task_id = o.task_id AND d.order_id = o.order_id
        WHERE d.task_id = #{taskId}
        <include refid="detailWhereFiltersFacet"/>
        ORDER BY v
        LIMIT 10000
    </select>

    <select id="findPage" resultMap="OrderDetailPageItemMap">
        SELECT d.*,
               o.area,
               o.representative_office,
               o.country,
               o.accounts,
               o.project,
               o.po_id,
               o.product_domain
        FROM t_order_product_detail_data d
        LEFT JOIN t_order_info o ON d.task_id = o.task_id AND d.order_id = o.order_id
        WHERE d.task_id = #{taskId}
        <include refid="detailWhereFilters"/>
        ORDER BY d.order_id, d.id
        LIMIT #{limit} OFFSET #{offset}
    </select>

    <select id="countByTask" resultType="long">
        SELECT COUNT(*)
        FROM t_order_product_detail_data d
        LEFT JOIN t_order_info o ON d.task_id = o.task_id AND d.order_id = o.order_id
        WHERE d.task_id = #{taskId}
        <include refid="detailWhereFilters"/>
    </select>

    <select id="findRowById" resultMap="DetailRowResultMap">
        SELECT * FROM t_order_product_detail_data WHERE id = #{id}
    </select>

    <update id="updateRow">
        UPDATE t_order_product_detail_data SET
            device_type = #{deviceType}, device_id = #{deviceId}, description = #{description}, category_type = #{categoryType},
            hardware_type = #{hardwareType}, scene = #{scene}, device_count = #{deviceCount}, income_month = #{incomeMonth}, currency = #{currency},
            list_price = #{listPrice}, before_tier = #{beforeTier}, before_price = #{beforePrice}, discount_desc_before = #{discountDescBefore},
            after_tier = #{afterTier}, after_price = #{afterPrice}, discount_desc_after = #{discountDescAfter},
            tier_increase = #{tierIncrease}, price_increase = #{priceIncrease}, after_tier_discount_rate = #{afterTierDiscountRate},
            after_price_discount_rate = #{afterPriceDiscountRate}, before_total_price = #{beforeTotalPrice}, after_total_price = #{afterTotalPrice},
            total_price_increase = #{totalPriceIncrease}, total_increase_rate = #{totalIncreaseRate}, gross_profit = #{grossProfit}, addition_info = #{additionInfo}
        WHERE id = #{id} AND task_id = #{taskId}
    </update>

    <select id="findAllByTask" resultMap="DetailRowResultMap">
        SELECT * FROM t_order_product_detail_data WHERE task_id = #{taskId}
    </select>
</mapper>
